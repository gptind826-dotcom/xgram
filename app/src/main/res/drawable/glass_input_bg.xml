<?xml version="1.0" encoding="utf-8"?>
<!--
    ɢʟᴀꜱꜱ_ɪɴᴘᴜᴛ_ʙɢ.хᴍʟ
    ᴛʀᴀɴꜱᴘᴀʀᴇɴᴛ ɪɴᴘᴜᴛ ꜰɪᴇʟᴅ ᴡɪᴛʜ ɢʟᴀꜱꜱ ʙᴏʀᴅᴇʀ
    ᴄʜᴀɴɢᴇꜱ ʙᴏʀᴅᴇʀ ᴄᴏʟᴏʀ ᴏɴ ꜰᴏᴄᴜꜱ
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/glass_input_bg" />
            <stroke android:width="1.5px" android:color="@color/glass_input_stroke_focus" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/glass_input_bg" />
            <stroke android:width="1px" android:color="@color/glass_input_stroke" />
        </shape>
    </item>
</selector>
