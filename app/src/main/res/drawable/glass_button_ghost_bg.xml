<!--
    ɢʟᴀꜱꜱ_ʙᴜᴛᴛᴏɴ_ɢʜᴏꜱᴛ_ʙɢ.хᴍʟ
    ɢʜᴏꜱᴛ ʙᴜᴛᴛᴏɴ — ᴛʀᴀɴꜱᴘᴀʀᴇɴᴛ ᴡɪᴛʜ ʙᴏʀᴅᴇʀ ᴏɴ ʜᴏᴠᴇʀ
    ᴜꜱᴇᴅ ꜰᴏʀ ʟᴇꜱꜱ ᴘʀᴏᴍɪɴᴇɴᴛ ᴀᴄᴛɪᴏɴꜱ
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/glass_bg_layer2" />
            <stroke android:width="1px" android:color="@color/glass_border_medium" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/glass_button_ghost_bg" />
            <stroke android:width="1px" android:color="#00FFFFFF" />
        </shape>
    </item>
</selector>
