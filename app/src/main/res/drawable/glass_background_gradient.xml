<?xml version="1.0" encoding="utf-8"?>
<!--
    ЙўКҹбҙҖкңұкңұ_КҷбҙҖбҙ„бҙӢЙўКҖбҙҸбҙңЙҙбҙ…_ЙўКҖбҙҖбҙ…ЙӘбҙҮЙҙбҙӣ.С…бҙҚКҹ
    бҙҸКҷкңұЙӘбҙ…ЙӘбҙҖЙҙ ЙӘбҙ„бҙҮ ЙўКҖбҙҖбҙ…ЙӘбҙҮЙҙбҙӣ кң°бҙҸКҖ КҹЙӘЗ«бҙңЙӘбҙ… ЙўКҹбҙҖкңұкңұ бҙЎЙӘЙҙбҙ…бҙҸбҙЎ КҷбҙҖбҙ„бҙӢЙўКҖбҙҸбҙңЙҙбҙ…
    бҙңкңұбҙҮбҙ… бҙҖкңұ бҙӣКңбҙҮ КҷбҙҖкңұбҙҮ КҹбҙҖКҸбҙҮКҖ КҷбҙҮКңЙӘЙҙбҙ… бҙҖКҹКҹ ЙўКҹбҙҖкңұкңұ бҙҳбҙҖЙҙбҙҮКҹкңұ
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- КҷбҙҖкңұбҙҮ ЙўКҖбҙҖбҙ…ЙӘбҙҮЙҙбҙӣ КҹбҙҖКҸбҙҮКҖ -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/bg_gradient_start"
                android:centerColor="@color/bg_gradient_mid"
                android:endColor="@color/bg_gradient_end"
                android:centerX="0.5"
                android:centerY="0.5" />
        </shape>
    </item>
    <!-- кңұбҙңКҷбҙӣКҹбҙҮ ЙӘбҙ„бҙҮ ЙўКҹбҙҸбҙЎ бҙҸбҙ бҙҮКҖКҹбҙҖКҸ -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="80%p"
                android:centerX="0.5"
                android:centerY="0.3"
                android:startColor="#0D26C6DA"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
