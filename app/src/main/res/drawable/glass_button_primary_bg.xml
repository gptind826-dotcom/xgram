<?xml version="1.0" encoding="utf-8"?>
<!--
    ЙўКҹбҙҖкңұкңұ_КҷбҙңбҙӣбҙӣбҙҸЙҙ_бҙҳКҖЙӘбҙҚбҙҖКҖКҸ_КҷЙў.С…бҙҚКҹ
    бҙҳКҖЙӘбҙҚбҙҖКҖКҸ бҙҖбҙ„бҙӣЙӘбҙҸЙҙ КҷбҙңбҙӣбҙӣбҙҸЙҙ бҙЎЙӘбҙӣКң ЙўКҹбҙҖкңұкңұ бҙҖбҙ„бҙ„бҙҮЙҙбҙӣ ЙўКҖбҙҖбҙ…ЙӘбҙҮЙҙбҙӣ
    КҷКҖЙӘЙўКңбҙӣ бҙ„КҸбҙҖЙҙ-КҷКҹбҙңбҙҮ ЙўКҹбҙҸбҙЎ кң°бҙҸКҖ бҙ„бҙӣбҙҖ КҷбҙңбҙӣбҙӣбҙҸЙҙкңұ
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/glass_accent_bright" />
            <stroke android:width="1px" android:color="#80FFFFFF" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#4D24BDBD" />
            <stroke android:width="1px" android:color="#1AFFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/glass_accent"
                android:endColor="@color/glass_accent_bright" />
            <stroke android:width="1px" android:color="#4DFFFFFF" />
        </shape>
    </item>
</selector>
