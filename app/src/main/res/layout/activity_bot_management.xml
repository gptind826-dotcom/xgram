<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/glass_background_gradient">

    <!-- ᴛᴏᴏʟʙᴀʀ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/glass_nav_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/botBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/glass_text_secondary"
            android:contentDescription="@string/action_back" />

        <TextView
            android:id="@+id/botManagementTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_bot_profile"
            android:textAppearance="@style/GlassText.Title"
            android:textColor="@color/glass_text_primary"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ʙᴏᴛ ɴᴀᴍᴇ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_bot_name"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/botNameInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_input_bg"
                android:textColor="@color/glass_input_text"
                android:textColorHint="@color/glass_input_hint"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:layout_marginBottom="16dp" />

            <!-- ʙᴏᴛ ᴅᴇꜱᴄʀɪᴘᴛɪᴏɴ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_bot_description"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/botDescriptionInput"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/glass_input_bg"
                android:textColor="@color/glass_input_text"
                android:textColorHint="@color/glass_input_hint"
                android:textSize="16sp"
                android:padding="16dp"
                android:gravity="top|start"
                android:inputType="text|textMultiLine"
                android:layout_marginBottom="16dp" />

            <!-- ᴀʙᴏᴜᴛ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_bot_about"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/botAboutInput"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/glass_input_bg"
                android:textColor="@color/glass_input_text"
                android:textColorHint="@color/glass_input_hint"
                android:textSize="16sp"
                android:padding="16dp"
                android:gravity="top|start"
                android:inputType="text|textMultiLine"
                android:layout_marginBottom="24dp" />

            <!-- ꜱᴀᴠᴇ ʙᴜᴛᴛᴏɴ -->
            <Button
                android:id="@+id/saveBotButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_button_primary_bg"
                android:text="@string/action_save"
                android:textColor="@color/glass_button_primary_text"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="24dp" />

            <!-- ᴄᴏᴍᴍᴀɴᴅ ɪɴꜱᴘᴇᴄᴛᴏʀ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inspector_title"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/clearLogButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/glass_button_secondary_bg"
                android:text="@string/inspector_clear"
                android:textColor="@color/glass_button_secondary_text"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <ScrollView
                android:id="@+id/inspectorScrollView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/glass_card_bg">

                <LinearLayout
                    android:id="@+id/inspectorContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/inspectorEmptyText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/inspector_empty"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_tertiary" />
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
