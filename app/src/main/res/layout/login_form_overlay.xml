<?xml version="1.0" encoding="utf-8"?>
<!--
    ʟᴏɢɪɴ_ꜰᴏʀᴍ_ᴏᴠᴇʀʟᴀʏ.хᴍʟ — ᴍʏᴛᴇʟᴇɢʀᴀᴍᴀᴘᴘ
    ᴅʏɴᴀᴍɪᴄ ʟᴏɢɪɴ ꜰᴏʀᴍ ᴛʜᴀᴛ ᴀᴅᴀᴘᴛꜱ ʙᴀꜱᴇᴅ ᴏɴ ꜱᴇʟᴇᴄᴛᴇᴅ ʟᴏɢɪɴ ᴍᴇᴛʜᴏᴅ
    ᴜꜱᴇᴅ ᴀꜱ ᴀɴ ᴏᴠᴇʀʟᴀʏ ᴏɴ ᴛᴏᴘ ᴏꜰ ʟᴏɢɪɴᴀᴄᴛɪᴠɪᴛʏ
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ʙᴀᴄᴋ ʙᴜᴛᴛᴏɴ ᴀɴᴅ ᴛɪᴛʟᴇ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/formBackButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/glass_text_secondary"
                android:contentDescription="@string/action_back" />

            <TextView
                android:id="@+id/formTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textAppearance="@style/GlassText.Headline.Small"
                android:textColor="@color/glass_text_primary"
                android:gravity="center" />

            <View
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <!-- ꜰᴏʀᴍ ᴅᴇꜱᴄʀɪᴘᴛɪᴏɴ -->
        <TextView
            android:id="@+id/formDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textAppearance="@style/GlassText.Body"
            android:textColor="@color/glass_text_secondary"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:layout_gravity="center_horizontal" />

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ᴘʜᴏɴᴇ ɴᴜᴍʙᴇʀ ꜰᴏʀᴍ (ᴠɪꜱɪʙɪʟɪᴛʏ ᴛᴏɢɢʟᴇᴅ) -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/phoneFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ᴄᴏᴜɴᴛʀʏ ᴄᴏᴅᴇ ɪɴᴘᴜᴛ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_country_code"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/countryCodeInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_input_bg"
                android:hint="@string/login_phone_example"
                android:textColor="@color/glass_input_text"
                android:textColorHint="@color/glass_input_hint"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="phone"
                android:maxLength="5"
                android:layout_marginBottom="16dp" />

            <!-- ᴘʜᴏɴᴇ ɴᴜᴍʙᴇʀ ɪɴᴘᴜᴛ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_phone_number"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/phoneNumberInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_input_bg"
                android:hint="@string/login_phone_hint"
                android:textColor="@color/glass_input_text"
                android:textColorHint="@color/glass_input_hint"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="phone"
                android:layout_marginBottom="24dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ʙᴏᴛ ᴛᴏᴋᴇɴ ꜰᴏʀᴍ (ᴠɪꜱɪʙɪʟɪᴛʏ ᴛᴏɢɢʟᴇᴅ) -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/botFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ʙᴏᴛ ᴛᴏᴋᴇɴ ɪɴᴘᴜᴛ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_bot_label"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/botTokenInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/glass_input_bg"
                android:hint="@string/login_bot_hint"
                android:textColor="@color/glass_input_text"
                android:textColorHint="@color/glass_input_hint"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:layout_marginBottom="8dp" />

            <!-- ʜɪɴᴛ ᴛᴇхᴛ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_bot_example"
                android:textAppearance="@style/GlassText.Caption"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="24dp" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ꜱᴛʀɪɴɢ ꜱᴇꜱꜱɪᴏɴ ꜰᴏʀᴍ (ᴠɪꜱɪʙɪʟɪᴛʏ ᴛᴏɢɢʟᴇᴅ) -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/sessionFormContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ꜱᴇꜱꜱɪᴏɴ ꜱᴛʀɪɴɢ ɪɴᴘᴜᴛ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_session_label"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/sessionStringInput"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/glass_input_bg"
                android:hint="@string/login_session_hint"
                android:textColor="@color/glass_input_text"
                android:textColorHint="@color/glass_input_hint"
                android:textSize="14sp"
                android:padding="16dp"
                android:gravity="top|start"
                android:inputType="text|textMultiLine"
                android:layout_marginBottom="8dp" />

            <!-- ᴀᴜᴛᴏ-ᴅᴇᴛᴇᴄᴛ ꜱᴛᴀᴛᴜꜱ -->
            <TextView
                android:id="@+id/sessionDetectStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_session_example"
                android:textAppearance="@style/GlassText.Caption"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="24dp" />
        </LinearLayout>

        <!-- ᴘʀɪᴍᴀʀʏ ᴀᴄᴛɪᴏɴ ʙᴜᴛᴛᴏɴ -->
        <Button
            android:id="@+id/loginActionButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/glass_button_primary_bg"
            android:text="@string/action_connect"
            android:textColor="@color/glass_button_primary_text"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="12dp" />

        <!-- ꜱᴇᴄᴏɴᴅᴀʀʏ ᴀᴄᴛɪᴏɴ ʙᴜᴛᴛᴏɴ (ʀᴇꜱᴇɴᴅ, ʙᴀᴄᴋ, ᴇᴛᴄ.) -->
        <Button
            android:id="@+id/loginSecondaryButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/glass_button_ghost_bg"
            android:text="@string/action_cancel"
            android:textColor="@color/glass_button_ghost_text"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />

        <!-- ꜱᴛᴀᴛᴜꜱ / ᴇʀʀᴏʀ ᴛᴇхᴛ -->
        <TextView
            android:id="@+id/loginStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textAppearance="@style/GlassText.Body.Small"
            android:textColor="@color/glass_text_secondary"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
