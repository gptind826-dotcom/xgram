<?xml version="1.0" encoding="utf-8"?>
<!--
    біАбіДбіЫ…™бі†…™біЫ П_біНбіА…™…і.—ЕбіН Я вАФ біН ПбіЫбіЗ ЯбіЗ…Ґ АбіАбіНбіАбіШбіШ
    біШбіПкЬ±біЫ-біАбіЬбіЫ ЬбіЗ…ібіЫ…™біДбіАбіЫ…™біП…і біЕбіАкЬ± Ь ЩбіПбіА АбіЕ бі°…™біЫ Ь  Я…™«ЂбіЬ…™біЕ …Ґ ЯбіАкЬ±кЬ± …ібіАбі†…™…ҐбіАбіЫ…™біП…і
    - кЬ∞ АбіПкЬ±біЫбіЗбіЕ …Ґ ЯбіАкЬ±кЬ± кЬ±біЗбіА АбіД Ь  ЩбіА А
    - біД ЬбіАбіЫ / біД ЬбіА…і…ібіЗ ЯкЬ± / …Ґ АбіПбіЬбіШкЬ± / біДбіП…ібіЫбіАбіДбіЫкЬ± біЫбіА ЩкЬ±
    - біШ АбіПкЬ∞…™ ЯбіЗ біНбіА…ібіА…ҐбіЗбіНбіЗ…ібіЫ
    - біДбіП…ібіЕ…™біЫ…™біП…ібіА Я кЬ±біЗбіЫбіЫ…™…і…ҐкЬ± (біЬкЬ±біЗ А бі†кЬ±.  ЩбіПбіЫ)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glass_background_gradient">

    <!--  ЩбіАбіДбіЛ…Ґ АбіПбіЬ…ібіЕ …™біНбіА…ҐбіЗ -->
    <ImageView
        android:id="@+id/mainBackgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- …Ґ ЯбіАкЬ±кЬ± біЕ…™біН біПбі†біЗ А ЯбіА П -->
    <View
        android:id="@+id/mainDimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D90A0E14" />

    <!-- біНбіА…™…і біДбіП…ібіЫбіЗ…ібіЫ біДбіП…ібіЫбіА…™…ібіЗ А -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- …Ґ ЯбіАкЬ±кЬ± біЫбіПбіП Я ЩбіА А / кЬ±біЗбіА АбіД Ь  ЩбіА А -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/glass_nav_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- біЫ…™біЫ ЯбіЗ  АбіПбі° -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/mainTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_title"
                    android:textAppearance="@style/GlassText.Headline.Small"
                    android:textColor="@color/glass_text_primary" />

                <ImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_preferences"
                    android:tint="@color/glass_text_secondary"
                    android:contentDescription="@string/action_settings" />
            </LinearLayout>

            <!-- кЬ±біЗбіА АбіД Ь  ЩбіА А -->
            <EditText
                android:id="@+id/searchInput"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/glass_search_bg"
                android:hint="@string/main_search_hint"
                android:textColor="@color/glass_search_text"
                android:textColorHint="@color/glass_search_hint"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawableTint="@color/glass_search_hint"
                android:drawablePadding="12dp"
                android:inputType="text"
                android:imeOptions="actionSearch" />
        </LinearLayout>

        <!-- біЫбіА Щ  ЯбіА ПбіПбіЬбіЫ -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/mainTabLayout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/glass_nav_bg"
            app:tabTextColor="@color/glass_text_secondary"
            app:tabSelectedTextColor="@color/glass_accent_bright"
            app:tabIndicatorColor="@color/glass_accent_bright"
            app:tabIndicatorHeight="2dp"
            app:tabIndicatorFullWidth="false"
            app:tabMode="fixed"
            app:tabGravity="fill" />

        <!-- бі†…™біЗбі° біШбіА…ҐбіЗ А кЬ∞біП А біЫбіА Щ біДбіП…ібіЫбіЗ…ібіЫ -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/mainViewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!--  ЩбіПбіЫбіЫбіПбіН …ібіАбі†…™…ҐбіАбіЫ…™біП…і -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/mainBottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@drawable/glass_nav_bg"
        app:itemIconTint="@color/glass_nav_selector"
        app:itemTextColor="@color/glass_nav_selector"
        app:itemIconSize="22dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/main_bottom_nav" />

    <!-- кЬ∞ ЯбіПбіАбіЫ…™…і…Ґ біАбіДбіЫ…™біП…і  ЩбіЬбіЫбіЫбіП…і (…ібіЗбі° біД ЬбіАбіЫ) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:src="@android:drawable/ic_menu_edit"
        android:tint="@color/glass_button_primary_text"
        app:backgroundTint="@color/glass_accent"
        app:elevation="4dp"
        android:contentDescription="@string/chat_input_hint" />

    <!-- кЬ±біЗбіЫбіЫ…™…і…ҐкЬ± біШбіА…ібіЗ Я (кЬ± Я…™біЕбіЗ-…™…і кЬ± ЬбіЗбіЗбіЫ, …™…і…™біЫ…™біА Я Я П …ҐбіП…ібіЗ) -->
    <FrameLayout
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:visibility="gone">

        <include layout="@layout/settings_panel" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
