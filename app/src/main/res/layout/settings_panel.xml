<?xml version="1.0" encoding="utf-8"?>
<!--
    кңұбҙҮбҙӣбҙӣЙӘЙҙЙўкңұ_бҙҳбҙҖЙҙбҙҮКҹ.С…бҙҚКҹ вҖ” бҙҚКҸбҙӣбҙҮКҹбҙҮЙўКҖбҙҖбҙҚбҙҖбҙҳбҙҳ
    бҙ„бҙҸЙҙбҙ…ЙӘбҙӣЙӘбҙҸЙҙбҙҖКҹ кңұбҙҮбҙӣбҙӣЙӘЙҙЙўкңұ бҙҳбҙҖЙҙбҙҮКҹ
    бҙ„бҙҸЙҙбҙӣбҙҮС…бҙӣ бҙ ЙӘбҙҮбҙЎ бҙҖ: бҙңкңұбҙҮКҖ бҙҖбҙ„бҙ„бҙҸбҙңЙҙбҙӣ кңұбҙҮбҙӣбҙӣЙӘЙҙЙўкңұ
    бҙ„бҙҸЙҙбҙӣбҙҮС…бҙӣ бҙ ЙӘбҙҮбҙЎ Кҷ: КҷбҙҸбҙӣ бҙӣбҙҸбҙӢбҙҮЙҙ кңұбҙҮбҙӣбҙӣЙӘЙҙЙўкңұ
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/glass_dark_surface">

    <!-- бҙӣбҙҸбҙҸКҹКҷбҙҖКҖ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/glass_nav_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/settingsCloseButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:tint="@color/glass_text_secondary"
            android:contentDescription="@string/action_close" />

        <TextView
            android:id="@+id/settingsPanelTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textAppearance="@style/GlassText.Title"
            android:textColor="@color/glass_text_primary"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- кңұбҙ„КҖбҙҸКҹКҹбҙҖКҷКҹбҙҮ бҙ„бҙҸЙҙбҙӣбҙҮЙҙбҙӣ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
            <!-- бҙҳКҖбҙҸкң°ЙӘКҹбҙҮ КңбҙҮбҙҖбҙ…бҙҮКҖ -->
            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/glass_card_bg"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/glass_avatar_placeholder">

                    <TextView
                        android:id="@+id/settingsAvatarInitial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="U"
                        android:textColor="@color/glass_accent_bright"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-thin" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settingsProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textAppearance="@style/GlassText.Title"
                        android:textColor="@color/glass_text_primary" />

                    <TextView
                        android:id="@+id/settingsProfileStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_online"
                        android:textAppearance="@style/GlassText.Body.Small"
                        android:textColor="@color/glass_text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
            <!-- КҷбҙҖбҙ„бҙӢЙўКҖбҙҸбҙңЙҙбҙ… бҙңКҖКҹ бҙ„бҙҸЙҙкң°ЙӘЙўбҙңКҖбҙҖбҙӣЙӘбҙҸЙҙ -->
            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_background_url"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/backgroundUrlInput"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/glass_input_bg"
                    android:hint="@string/settings_background_url_hint"
                    android:textColor="@color/glass_input_text"
                    android:textColorHint="@color/glass_input_hint"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="textUri" />

                <Button
                    android:id="@+id/backgroundApplyButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/glass_button_primary_bg"
                    android:text="@string/settings_background_apply"
                    android:textColor="@color/glass_button_primary_text"
                    android:textSize="12sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />
            </LinearLayout>

            <Button
                android:id="@+id/backgroundDefaultButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/glass_button_ghost_bg"
                android:text="@string/settings_background_default"
                android:textColor="@color/glass_button_ghost_text"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
            <!-- бҙ„бҙҸЙҙбҙӣбҙҮС…бҙӣ бҙ ЙӘбҙҮбҙЎ бҙҖ: бҙңкңұбҙҮКҖ бҙҖбҙ„бҙ„бҙҸбҙңЙҙбҙӣ кңұбҙҮбҙӣбҙӣЙӘЙҙЙўкңұ -->
            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->

            <LinearLayout
                android:id="@+id/userSettingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_account"
                    android:textAppearance="@style/GlassText.Label"
                    android:textColor="@color/glass_text_tertiary"
                    android:layout_marginBottom="8dp" />

                <!-- бҙҮбҙ…ЙӘбҙӣ бҙҳКҖбҙҸкң°ЙӘКҹбҙҮ -->
                <LinearLayout
                    android:id="@+id/editProfileRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_edit"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_edit_profile"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- бҙӣбҙЎбҙҸ-кңұбҙӣбҙҮбҙҳ бҙ бҙҮКҖЙӘкң°ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙ -->
                <LinearLayout
                    android:id="@+id/twoStepRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_two_step"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- бҙҖбҙ„бҙӣЙӘбҙ бҙҮ кңұбҙҮкңұкңұЙӘбҙҸЙҙкңұ -->
                <LinearLayout
                    android:id="@+id/activeSessionsRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_history"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_active_sessions"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- бҙҳКҖЙӘбҙ бҙҖбҙ„КҸ -->
                <LinearLayout
                    android:id="@+id/privacyRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_view"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_privacy"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
            <!-- бҙ„бҙҸЙҙбҙӣбҙҮС…бҙӣ бҙ ЙӘбҙҮбҙЎ Кҷ: КҷбҙҸбҙӣ кңұбҙҮбҙӣбҙӣЙӘЙҙЙўкңұ -->
            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->

            <LinearLayout
                android:id="@+id/botSettingsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_bot_profile"
                    android:textAppearance="@style/GlassText.Label"
                    android:textColor="@color/glass_text_tertiary"
                    android:layout_marginBottom="8dp" />

                <!-- КҷбҙҸбҙӣ ЙҙбҙҖбҙҚбҙҮ -->
                <LinearLayout
                    android:id="@+id/botNameRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_bot_name"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- КҷбҙҸбҙӣ бҙ…бҙҮкңұбҙ„КҖЙӘбҙҳбҙӣЙӘбҙҸЙҙ -->
                <LinearLayout
                    android:id="@+id/botDescriptionRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_bot_description"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- бҙ„бҙҸбҙҚбҙҚбҙҖЙҙбҙ… ЙӘЙҙкңұбҙҳбҙҮбҙ„бҙӣбҙҸКҖ -->
                <LinearLayout
                    android:id="@+id/commandInspectorRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_sort"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_command_inspector"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- КҷбҙҸбҙӣ бҙЎбҙҮКҷКңбҙҸбҙҸбҙӢ -->
                <LinearLayout
                    android:id="@+id/botWebhookRow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/glass_card_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_set_as"
                        android:tint="@color/glass_text_secondary"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_bot_webhook"
                        android:textAppearance="@style/GlassText.Body"
                        android:textColor="@color/glass_text_primary" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next"
                        android:tint="@color/glass_text_tertiary"
                        android:contentDescription="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
            <!-- бҙ„бҙҸбҙҚбҙҚбҙҸЙҙ кңұбҙҮбҙӣбҙӣЙӘЙҙЙўкңұ -->
            <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_appearance"
                android:textAppearance="@style/GlassText.Label"
                android:textColor="@color/glass_text_tertiary"
                android:layout_marginBottom="8dp" />

            <!-- ЙҙбҙҸбҙӣЙӘкң°ЙӘбҙ„бҙҖбҙӣЙӘбҙҸЙҙкңұ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/glass_card_bg"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_notifications"
                    android:tint="@color/glass_text_secondary"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_notifications"
                    android:textAppearance="@style/GlassText.Body"
                    android:textColor="@color/glass_text_primary" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/notificationsSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- КҹбҙҸЙўбҙҸбҙңбҙӣ КҷбҙңбҙӣбҙӣбҙҸЙҙ -->
            <Button
                android:id="@+id/logoutButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/glass_button_secondary_bg"
                android:text="@string/action_logout"
                android:textColor="@color/glass_error"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
