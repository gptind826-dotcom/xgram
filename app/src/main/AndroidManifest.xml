<?xml version="1.0" encoding="utf-8"?>
<!--
    ᴀɴᴅʀᴏɪᴅᴍᴀɴɪꜰᴇꜱᴛ.хᴍʟ — ᴍʏᴛᴇʟᴇɢʀᴀᴍᴀᴘᴘ
    ᴀᴘᴘʟɪᴄᴀᴛɪᴏɴ ᴍᴀɴɪꜰᴇꜱᴛ ᴡɪᴛʜ ꜰᴜʟʟ ᴘᴇʀᴍɪꜱꜱɪᴏɴ ꜱᴇᴛ ꜰᴏʀ ᴛᴇʟᴇɢʀᴀᴍ ᴀʟᴛᴇʀɴᴀᴛɪᴠᴇ
    ꜱᴜᴘᴘᴏʀᴛꜱ: ᴍᴛᴘʀᴏᴛᴏ ᴄᴏɴɴᴇᴄᴛɪᴏɴꜱ, ʙᴏᴛ ᴀᴘɪ, ꜱᴛʀɪɴɢ ꜱᴇꜱꜱɪᴏɴ ᴘᴀʀꜱɪɴɢ, ʙᴀᴄᴋɢʀᴏᴜɴᴅ ɪᴍᴀɢᴇ ʟᴏᴀᴅɪɴɢ
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.alternative.telegram">

    <!-- ɴᴇᴛᴡᴏʀᴋ ᴘᴇʀᴍɪꜱꜱɪᴏɴꜱ — ᴄᴏʀᴇ ꜰᴏʀ ᴀɴʏ ᴛᴇʟᴇɢʀᴀᴍ ᴄʟɪᴇɴᴛ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- ꜱᴍꜱ ᴘᴇʀᴍɪꜱꜱɪᴏɴꜱ ꜰᴏʀ ᴏᴛᴘ ᴀᴜᴛᴏ-ʀᴇᴀᴅ (ᴏᴘᴛɪᴏɴᴀʟ ꜰᴇᴀᴛᴜʀᴇ) -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- ᴘʜᴏɴᴇ ꜱᴛᴀᴛᴇ ꜰᴏʀ ᴄᴏᴜɴᴛʀʏ ᴄᴏᴅᴇ ᴅᴇᴛᴇᴄᴛɪᴏɴ -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />

    <!-- ɴᴏᴛɪꜰɪᴄᴀᴛɪᴏɴ ᴘᴇʀᴍɪꜱꜱɪᴏɴꜱ — ᴀɴᴅʀᴏɪᴅ 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- ᴡᴀᴋᴇ ʟᴏᴄᴋ ꜰᴏʀ ʙᴀᴄᴋɢʀᴏᴜɴᴅ ᴍᴇꜱꜱᴀɢᴇ ꜱʏɴᴄ -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ᴠɪʙʀᴀᴛɪᴏɴ ꜰᴏʀ ɴᴏᴛɪꜰɪᴄᴀᴛɪᴏɴꜱ -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ꜱᴛᴏʀᴀɢᴇ ꜰᴏʀ ɪᴍᴀɢᴇ ᴄᴀᴄʜɪɴɢ ᴀɴᴅ ʙᴀᴄᴋɢʀᴏᴜɴᴅ ᴅᴏᴡɴʟᴏᴀᴅꜱ -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- ʙɪᴏᴍᴇᴛʀɪᴄ ᴀᴜᴛʜᴇɴᴛɪᴄᴀᴛɪᴏɴ ꜰᴏʀ ꜱᴇᴄᴜʀɪᴛʏ -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!-- ʙʟᴏᴄᴋ ᴋᴇʏʙᴏᴀʀᴅ ꜱᴄʀᴇᴇɴ ᴄᴀᴘᴛᴜʀᴇ ɪɴ ꜱᴇɴꜱɪᴛɪᴠᴇ ꜰɪᴇʟᴅꜱ -->
    <uses-permission android:name="android.permission.FLAG_SECURE" />

    <!-- ʙᴀᴛᴛᴇʀʏ ᴏᴘᴛɪᴍɪᴢᴀᴛɪᴏɴ ᴇxᴇᴍᴘᴛɪᴏɴ ꜰᴏʀ ʙᴀᴄᴋɢʀᴏᴜɴᴅ ꜱᴇʀᴠɪᴄᴇ -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- ʜᴀʀᴅᴡᴀʀᴇ ꜰᴇᴀᴛᴜʀᴇ ᴅᴇᴄʟᴀʀᴀᴛɪᴏɴꜱ -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />
    <uses-feature android:name="android.hardware.fingerprint" android:required="false" />
    <uses-feature android:name="android.hardware.screen.portrait" android:required="false" />

    <application
        android:name=".MyTelegramApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/AppTheme.LiquidGlass"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:extractNativeLibs="true"
        tools:targetApi="34">

        <!-- ʟᴏɢɪɴ ᴀᴄᴛɪᴠɪᴛʏ — ᴀᴘᴘ ᴇɴᴛʀʏ ᴘᴏɪɴᴛ (ᴛʜʀᴇᴇ-ᴡᴀʏ ɢᴀᴛᴇᴡᴀʏ) -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize|stateHidden"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ᴍᴀɪɴ ᴅᴀꜱʜʙᴏᴀʀᴅ ᴀᴄᴛɪᴠɪᴛʏ — ᴘᴏꜱᴛ-ᴀᴜᴛʜᴇɴᴛɪᴄᴀᴛɪᴏɴ ʜᴜʙ -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|smallestScreenSize" />

        <!-- ᴏᴛᴘ ᴠᴇʀɪꜰɪᴄᴀᴛɪᴏɴ ᴀᴄᴛɪᴠɪᴛʏ — ꜱᴍꜱ ᴄᴏᴅᴇ ɪɴᴘᴜᴛ -->
        <activity
            android:name=".OtpVerificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ᴘʀᴏꜰɪʟᴇ ꜱᴇᴛᴛɪɴɢꜱ ᴀᴄᴛɪᴠɪᴛʏ -->
        <activity
            android:name=".ProfileSettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ʙᴏᴛ ᴍᴀɴᴀɢᴇᴍᴇɴᴛ ᴀᴄᴛɪᴠɪᴛʏ -->
        <activity
            android:name=".BotManagementActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- ᴀᴄᴛɪᴠᴇ ꜱᴇꜱꜱɪᴏɴꜱ ᴠɪᴇᴡᴇʀ -->
        <activity
            android:name=".ActiveSessionsActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- ʙᴀᴄᴋɢʀᴏᴜɴᴅ ꜱʏɴᴄ ꜱᴇʀᴠɪᴄᴇ ꜰᴏʀ ᴍᴇꜱꜱᴀɢᴇꜱ -->
        <service
            android:name=".service.MessageSyncService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:enabled="true" />

        <!-- ꜱᴍꜱ ʀᴇᴄᴇɪᴠᴇʀ ꜰᴏʀ ᴏᴛᴘ ᴀᴜᴛᴏ-ᴄᴀᴘᴛᴜʀᴇ -->
        <receiver
            android:name=".receiver.SmsOtpReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- ɴᴇᴛᴡᴏʀᴋ ꜱᴛᴀᴛᴇ ʀᴇᴄᴇɪᴠᴇʀ -->
        <receiver
            android:name=".receiver.NetworkStateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- ɢʟɪᴅᴇ ᴍᴏᴅᴜʟᴇ ᴄᴏɴꜰɪɢᴜʀᴀᴛɪᴏɴ ꜰᴏʀ ɪᴍᴀɢᴇ ʟᴏᴀᴅɪɴɢ -->
        <meta-data
            android:name="com.alternative.telegram.GlideModule"
            android:value="GlideModule" />

    </application>

</manifest>
